# ══════════════════════════════════════════════════════════════
# Groq API Keys (free at https://console.groq.com)
# Using 3 keys distributes load across 6 agents to avoid rate limits
# ══════════════════════════════════════════════════════════════
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here
# ══════════════════════════════════════════════════════════════
# Model Configuration (defaults are good, no need to change)
# ══════════════════════════════════════════════════════════════
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.1

# ══════════════════════════════════════════════════════════════
# LangSmith Tracing (free at https://smith.langchain.com)
# ══════════════════════════════════════════════════════════════
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=trustlens

